        :AnnotationProperty_alsoKnownAs,
        :AnnotationProperty_formerlyKnownAs,
        :AnnotationProperty_hasBirthYear,
        :AnnotationProperty_hasDeathYear,
        :AnnotationProperty_hasMarriageYear,
        :AnnotationProperty_knownAs,
        :Man-hasSex,
        :Man-isBrotherOf,
        :Man-isFatherOf,
        :Man-isHusbandOf,
        :Man-isMalePartnerIn,
        :Man-isSonOf,
        :Man-isUncleOf,
        :Person-hasAncestor,
        :Person-hasBrother,
        :Person-hasFather,
        :Person-hasHusband,
        :Person-hasMother,
        :Person-hasParent,
        :Person-hasRelation,
        :Person-hasSex,
        :Person-hasSister,
        :Person-hasSpouse,
        :Person-hasWife,
        :Person-isBloodrelationOf,
        :Person-isChildOf,
        :Person-isPartnerIn,
        :Person-isSiblingOf,
        :Person-isSpouseOf ;
    sh:rule esh:InferTypeRule_DomainEntity,
        esh:InferTypeRule_Person .

:Marriage a rdfs:Class,
        sh:NodeShape ;
    esh:disjointWith :Ancestor,
        :Female,
        :Male,
        :Man,
        :Person,
        :Sex,
        :Woman ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :AnnotationProperty_alsoKnownAs,
        :AnnotationProperty_formerlyKnownAs,
        :AnnotationProperty_hasBirthYear,
        :AnnotationProperty_hasDeathYear,
        :AnnotationProperty_hasMarriageYear,
        :AnnotationProperty_knownAs,
        :Marriage-hasFemalePartner,
        :Marriage-hasMalePartner,
        :Marriage-hasPartner ;
    sh:rule esh:InferTypeRule_DomainEntity .

