        :AnnotationProperty_knownAs,
        :Man-hasSex,
        :Man-isBrotherOf,
        :Man-isFatherOf,
        :Man-isHusbandOf,
        :Man-isMalePartnerIn,
        :Man-isSonOf,
        :Man-isUncleOf,
        :Person-hasAncestor,
        :Person-hasBrother,
        :Person-hasFather,
        :Person-hasHusband,
        :Person-hasMother,
        :Person-hasParent,
        :Person-hasRelation,
        :Person-hasSex,
        :Person-hasSister,
        :Person-hasSpouse,
        :Person-hasWife,
        :Person-isBloodrelationOf,
        :Person-isChildOf,
        :Person-isPartnerIn,
        :Person-isSiblingOf,
        :Person-isSpouseOf,
        :Woman-hasSex,
