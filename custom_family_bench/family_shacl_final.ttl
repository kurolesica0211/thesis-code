:Woman a rdfs:Class,
        sh:NodeShape ;
    esh:disjointWith :Female,
        :Male,
        :Man,
        :Marriage,
        :Sex ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :Ancestor-hasChild,
        :Ancestor-hasDaughter,
        :Ancestor-hasSon,
        :Ancestor-isAncestorOf,
        :Ancestor-isFatherOf,
        :Ancestor-isMotherOf,
        :Ancestor-isParentOf,
        :AnnotationProperty_alsoKnownAs,
        :AnnotationProperty_formerlyKnownAs,
        :AnnotationProperty_hasBirthYear,
        :AnnotationProperty_hasDeathYear,
        :AnnotationProperty_hasMarriageYear,
        :AnnotationProperty_knownAs,
        :Person-hasAncestor,
        :Person-hasBrother,
        :Person-hasFather,
        :Person-hasHusband,
        :Person-hasMother,
        :Person-hasParent,
        :Person-hasRelation,
        :Person-hasSex,
        :Person-hasSister,
        :Person-hasSpouse,
        :Person-hasWife,
        :Person-isBloodrelationOf,
        :Person-isChildOf,
        :Person-isPartnerIn,
        :Person-isSiblingOf,
        :Person-isSpouseOf,
        :Woman-hasSex,
        :Woman-isAuntOf,
        :Woman-isDaughterOf,
        :Woman-isFemalePartnerIn,
