@prefix : <http://example.com/family_TBOX.ttl#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Ancestor a rdfs:Class,
        sh:NodeShape ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property
    #---------- Annotation Properties ------------
        :Ancestor-alsoKnownAs,
        :Ancestor-formerlyKnownAs,
        :Ancestor-knownAs,
        :Ancestor-hasBirthYear,
        :Ancestor-hasDeathYear,
        :Ancestor-hasMarriageYear,
    #--------- Ancestor's properties -------------
        :Ancestor-hasChild,
        :Ancestor-hasDaughter,
        :Ancestor-hasSon,
        :Ancestor-isAncestorOf,
        :Ancestor-isFatherOf,
        :Ancestor-isMotherOf,
        :Ancestor-isParentOf,
    #--------- Since Ancestor can be Man ---------
        :Man-hasSex,
        :Man-isBrotherOf,
        :Man-isFatherOf,
        :Man-isHusbandOf,
        :Man-isMalePartnerIn,
        :Man-isSonOf,
        :Man-isUncleOf,
    #--------- Since Ancestor can be Woman -------
        :Woman-hasSex,
        :Woman-isAuntOf,
        :Woman-isDaughterOf,
        :Woman-isFemalePartnerIn,
        :Woman-isMotherOf,
        :Woman-isSisterOf,
        :Woman-isWifeOf,
    #--------- Inherited Person's properties -----
        :Person-hasAncestor,
        :Person-hasBrother,
        :Person-hasFather,
        :Person-hasHusband,
        :Person-hasMother,
        :Person-hasParent,
        :Person-hasRelation,
        :Person-hasSex,
        :Person-hasSister,
        :Person-hasSpouse,
        :Person-hasWife,
        :Person-isBloodrelationOf,
        :Person-isChildOf,
        :Person-isPartnerIn,
        :Person-isSiblingOf,
        :Person-isSpouseOf .

:DomainEntity a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :DomainEntity-alsoKnownAs,
        :DomainEntity-formerlyKnownAs,
        :DomainEntity-hasBirthYear,
        :DomainEntity-hasDeathYear,
        :DomainEntity-hasMarriageYear,
        :DomainEntity-knownAs .

:Female a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :Female-alsoKnownAs,
        :Female-formerlyKnownAs,
        :Female-hasBirthYear,
        :Female-hasDeathYear,
        :Female-hasMarriageYear,
        :Female-knownAs .

:Male a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :Male-alsoKnownAs,
        :Male-formerlyKnownAs,
        :Male-hasBirthYear,
        :Male-hasDeathYear,
        :Male-hasMarriageYear,
        :Male-knownAs .

:Man a rdfs:Class,
        sh:NodeShape ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property
    #--------- Annotation Properties -------------
        :Man-alsoKnownAs,
        :Man-formerlyKnownAs,
        :Man-hasBirthYear,
        :Man-hasDeathYear,
        :Man-hasMarriageYear,
        :Man-knownAs,
    #--------- Man's properties ------------------
        :Man-hasSex,
        :Man-isBrotherOf,
        :Man-isFatherOf,
        :Man-isHusbandOf,
        :Man-isMalePartnerIn,
        :Man-isSonOf,
        :Man-isUncleOf,
    #--------- Inherited Person's properties -----
        :Person-hasAncestor,
        :Person-hasBrother,
        :Person-hasFather,
        :Person-hasHusband,
        :Person-hasMother,
        :Person-hasParent,
        :Person-hasRelation,
        :Person-hasSex,
        :Person-hasSister,
        :Person-hasSpouse,
        :Person-hasWife,
        :Person-isBloodrelationOf,
        :Person-isChildOf,
        :Person-isPartnerIn,
        :Person-isSiblingOf,
        :Person-isSpouseOf,
    #--------- Since Man can be Ancestor ---------
        :Ancestor-hasChild,
        :Ancestor-hasDaughter,
        :Ancestor-hasSon,
        :NotAncestor-isAncestorOf,
        :Ancestor-isFatherOf,
        :Ancestor-isMotherOf,
        :Ancestor-isParentOf .

:Marriage a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :Marriage-alsoKnownAs,
        :Marriage-formerlyKnownAs,
        :Marriage-hasBirthYear,
        :Marriage-hasDeathYear,
        :Marriage-hasFemalePartner,
        :Marriage-hasMalePartner,
        :Marriage-hasMarriageYear,
        :Marriage-hasPartner,
        :Marriage-knownAs .

:Person a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property
    #--------- Annotation properties -------------
        :Person-alsoKnownAs,
        :Person-formerlyKnownAs,
        :Person-hasBirthYear,
        :Person-hasDeathYear,
        :Person-hasMarriageYear,
        :Person-knownAs,
    #--------- Person's properties ---------------
        :Person-hasAncestor,
        :Person-hasBrother,
        :Person-hasFather,
        :Person-hasHusband,
        :Person-hasMother,
        :Person-hasParent,
        :Person-hasRelation,
        :Person-hasSex,
        :Person-hasSister,
        :Person-hasSpouse,
        :Person-hasWife,
        :Person-isBloodrelationOf,
        :Person-isChildOf,
        :Person-isPartnerIn,
        :Person-isSiblingOf,
        :Person-isSpouseOf,
    #--------- Since Person can be Ancestor ------
        :Ancestor-hasChild,
        :Ancestor-hasDaughter,
        :Ancestor-hasSon,
        :NotAncestor-isAncestorOf,
        :Ancestor-isFatherOf,
        :Ancestor-isMotherOf,
        :Ancestor-isParentOf,
    #--------- Since Person can be Man -----------
        :Man-hasSex,
        :Man-isBrotherOf,
        :Man-isFatherOf,
        :Man-isHusbandOf,
        :Man-isMalePartnerIn,
        :Man-isSonOf,
        :Man-isUncleOf,
    #--------- Since Person can be Woman ---------
        :Woman-hasSex,
        :Woman-isAuntOf,
        :Woman-isDaughterOf,
        :Woman-isFemalePartnerIn,
        :Woman-isMotherOf,
        :Woman-isSisterOf,
        :Woman-isWifeOf .
 
:Sex a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :Sex-alsoKnownAs,
        :Sex-formerlyKnownAs,
        :Sex-hasBirthYear,
        :Sex-hasDeathYear,
        :Sex-hasMarriageYear,
        :Sex-knownAs .

:Woman a rdfs:Class,
        sh:NodeShape ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property 
    #--------- Annotation properties -------------
        :Woman-alsoKnownAs,
        :Woman-formerlyKnownAs,
        :Woman-hasBirthYear,
        :Woman-hasDeathYear,
        :Woman-hasMarriageYear,
        :Woman-knownAs,
    #--------- Woman's properties ----------------
        :Woman-hasSex,
        :Woman-isAuntOf,
        :Woman-isDaughterOf,
        :Woman-isFemalePartnerIn,
        :Woman-isMotherOf,
        :Woman-isSisterOf,
        :Woman-isWifeOf,
    #--------- Inherited from Person -------------
        :Person-hasAncestor,
        :Person-hasBrother,
        :Person-hasFather,
        :Person-hasHusband,
        :Person-hasMother,
        :Person-hasParent,
        :Person-hasRelation,
        :Person-hasSex,
        :Person-hasSister,
        :Person-hasSpouse,
        :Person-hasWife,
        :Person-isBloodrelationOf,
        :Person-isChildOf,
        :Person-isPartnerIn,
        :Person-isSiblingOf,
        :Person-isSpouseOf,
    #--------- Since Woman can be Ancestor -------
        :Ancestor-hasChild,
        :Ancestor-hasDaughter,
        :Ancestor-hasSon,
        :NotAncestor-isAncestorOf,
        :Ancestor-isFatherOf,
        :Ancestor-isMotherOf,
        :Ancestor-isParentOf .

:Ancestor-alsoKnownAs a sh:PropertyShape ;
    sh:path :alsoKnownAs .

:Ancestor-formerlyKnownAs a sh:PropertyShape ;
    sh:path :formerlyKnownAs .

:Ancestor-hasBirthYear a sh:PropertyShape ;
    sh:path :hasBirthYear .

:Ancestor-hasChild a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :hasChild .

:Ancestor-hasDaughter a sh:PropertyShape ;
    sh:class :Woman ;
    sh:path :hasDaughter .

:Ancestor-hasDeathYear a sh:PropertyShape ;
    sh:path :hasDeathYear .

:Ancestor-hasMarriageYear a sh:PropertyShape ;
    sh:path :hasMarriageYear .

:Ancestor-hasSon a sh:PropertyShape ;
    sh:class :Man ;
    sh:path :hasSon .

:Ancestor-isAncestorOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:minCount 1 ;
    sh:path :isAncestorOf .

:NotAncestor-isAncestorOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isAncestorOf .

:Ancestor-isFatherOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isFatherOf .

:Ancestor-isMotherOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isMotherOf .

:Ancestor-isParentOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isParentOf .

:Ancestor-knownAs a sh:PropertyShape ;
    sh:path :knownAs .

:DomainEntity-alsoKnownAs a sh:PropertyShape ;
    sh:path :alsoKnownAs .

:DomainEntity-formerlyKnownAs a sh:PropertyShape ;
    sh:path :formerlyKnownAs .

:DomainEntity-hasBirthYear a sh:PropertyShape ;
    sh:path :hasBirthYear .

:DomainEntity-hasDeathYear a sh:PropertyShape ;
    sh:path :hasDeathYear .

:DomainEntity-hasMarriageYear a sh:PropertyShape ;
    sh:path :hasMarriageYear .

:DomainEntity-knownAs a sh:PropertyShape ;
    sh:path :knownAs .

:Female-alsoKnownAs a sh:PropertyShape ;
    sh:path :alsoKnownAs .

:Female-formerlyKnownAs a sh:PropertyShape ;
    sh:path :formerlyKnownAs .

:Female-hasBirthYear a sh:PropertyShape ;
    sh:path :hasBirthYear .

:Female-hasDeathYear a sh:PropertyShape ;
    sh:path :hasDeathYear .

:Female-hasMarriageYear a sh:PropertyShape ;
    sh:path :hasMarriageYear .

:Female-knownAs a sh:PropertyShape ;
    sh:path :knownAs .

:Male-alsoKnownAs a sh:PropertyShape ;
    sh:path :alsoKnownAs .

:Male-formerlyKnownAs a sh:PropertyShape ;
    sh:path :formerlyKnownAs .

:Male-hasBirthYear a sh:PropertyShape ;
    sh:path :hasBirthYear .

:Male-hasDeathYear a sh:PropertyShape ;
    sh:path :hasDeathYear .

:Male-hasMarriageYear a sh:PropertyShape ;
    sh:path :hasMarriageYear .

:Male-knownAs a sh:PropertyShape ;
    sh:path :knownAs .

:Man-alsoKnownAs a sh:PropertyShape ;
    sh:path :alsoKnownAs .

:Man-formerlyKnownAs a sh:PropertyShape ;
    sh:path :formerlyKnownAs .

:Man-hasBirthYear a sh:PropertyShape ;
    sh:path :hasBirthYear .

:Man-hasDeathYear a sh:PropertyShape ;
    sh:path :hasDeathYear .

:Man-hasMarriageYear a sh:PropertyShape ;
    sh:path :hasMarriageYear .

:Man-hasSex a sh:PropertyShape ;
    dash:hasValueWithClass :Male ;
    sh:class :Sex ;
    sh:maxCount 1 ;
    sh:path :hasSex .

:Man-isBrotherOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isBrotherOf .

:Man-isFatherOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isFatherOf .

:Man-isHusbandOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isHusbandOf .

:Man-isMalePartnerIn a sh:PropertyShape ;
    sh:class :Marriage ;
    sh:path :isMalePartnerIn .

:Man-isSonOf a sh:PropertyShape ;
    sh:class :Ancestor ;
    sh:path :isSonOf .

:Man-isUncleOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isUncleOf .

:Man-knownAs a sh:PropertyShape ;
    sh:path :knownAs .

:Marriage-alsoKnownAs a sh:PropertyShape ;
    sh:path :alsoKnownAs .

:Marriage-formerlyKnownAs a sh:PropertyShape ;
    sh:path :formerlyKnownAs .

:Marriage-hasBirthYear a sh:PropertyShape ;
    sh:path :hasBirthYear .

:Marriage-hasDeathYear a sh:PropertyShape ;
    sh:path :hasDeathYear .

:Marriage-hasFemalePartner a sh:PropertyShape ;
    sh:class :Woman ;
    sh:path :hasFemalePartner .

:Marriage-hasMalePartner a sh:PropertyShape ;
    sh:class :Man ;
    sh:path :hasMalePartner .

:Marriage-hasMarriageYear a sh:PropertyShape ;
    sh:path :hasMarriageYear .

:Marriage-hasPartner a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :hasPartner .

:Marriage-knownAs a sh:PropertyShape ;
    sh:path :knownAs .

:Person-alsoKnownAs a sh:PropertyShape ;
    sh:path :alsoKnownAs .

:Person-formerlyKnownAs a sh:PropertyShape ;
    sh:path :formerlyKnownAs .

:Person-hasAncestor a sh:PropertyShape ;
    sh:class :Ancestor ;
    sh:path :hasAncestor .

:Person-hasBirthYear a sh:PropertyShape ;
    sh:path :hasBirthYear .

:Person-hasBrother a sh:PropertyShape ;
    sh:class :Man ;
    sh:path :hasBrother .

:Person-hasDeathYear a sh:PropertyShape ;
    sh:path :hasDeathYear .

:Person-hasFather a sh:PropertyShape ;
    sh:class :Ancestor,
        :Man ;
    sh:maxCount 1 ;
    sh:path :hasFather .

:Person-hasHusband a sh:PropertyShape ;
    sh:class :Man ;
    sh:path :hasHusband .

:Person-hasMarriageYear a sh:PropertyShape ;
    sh:path :hasMarriageYear .

:Person-hasMother a sh:PropertyShape ;
    sh:class :Ancestor,
        :Woman ;
    sh:maxCount 1 ;
    sh:path :hasMother .

:Person-hasParent a sh:PropertyShape ;
    sh:class :Ancestor,
        :Person ;
    sh:maxCount 2 ;
    sh:path :hasParent .

:Person-hasRelation a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :hasRelation .

:Person-hasSex a sh:PropertyShape ;
    sh:class :Sex ;
    sh:maxCount 1 ;
    sh:path :hasSex .

:Person-hasSister a sh:PropertyShape ;
    sh:class :Woman ;
    sh:path :hasSister .

:Person-hasSpouse a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :hasSpouse .

:Person-hasWife a sh:PropertyShape ;
    sh:class :Woman ;
    sh:path :hasWife .

:Person-isBloodrelationOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isBloodrelationOf .

:Person-isChildOf a sh:PropertyShape ;
    sh:class :Ancestor ;
    sh:path :isChildOf .

:Person-isPartnerIn a sh:PropertyShape ;
    sh:class :Marriage ;
    sh:path :isPartnerIn .

:Person-isSiblingOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isSiblingOf .

:Person-isSpouseOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isSpouseOf .

:Person-knownAs a sh:PropertyShape ;
    sh:path :knownAs .

:Sex-alsoKnownAs a sh:PropertyShape ;
    sh:path :alsoKnownAs .

:Sex-formerlyKnownAs a sh:PropertyShape ;
    sh:path :formerlyKnownAs .

:Sex-hasBirthYear a sh:PropertyShape ;
    sh:path :hasBirthYear .

:Sex-hasDeathYear a sh:PropertyShape ;
    sh:path :hasDeathYear .

:Sex-hasMarriageYear a sh:PropertyShape ;
    sh:path :hasMarriageYear .

:Sex-knownAs a sh:PropertyShape ;
    sh:path :knownAs .

:Woman-alsoKnownAs a sh:PropertyShape ;
    sh:path :alsoKnownAs .

:Woman-formerlyKnownAs a sh:PropertyShape ;
    sh:path :formerlyKnownAs .

:Woman-hasBirthYear a sh:PropertyShape ;
    sh:path :hasBirthYear .

:Woman-hasDeathYear a sh:PropertyShape ;
    sh:path :hasDeathYear .

:Woman-hasMarriageYear a sh:PropertyShape ;
    sh:path :hasMarriageYear .

:Woman-hasSex a sh:PropertyShape ;
    dash:hasValueWithClass :Female ;
    sh:class :Sex ;
    sh:maxCount 1 ;
    sh:path :hasSex .

:Woman-isAuntOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isAuntOf .

:Woman-isDaughterOf a sh:PropertyShape ;
    sh:class :Ancestor ;
    sh:path :isDaughterOf .

:Woman-isFemalePartnerIn a sh:PropertyShape ;
    sh:class :Marriage ;
    sh:path :isFemalePartnerIn .

:Woman-isMotherOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isMotherOf .

:Woman-isSisterOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isSisterOf .

:Woman-isWifeOf a sh:PropertyShape ;
    sh:class :Person ;
    sh:path :isWifeOf .

:Woman-knownAs a sh:PropertyShape ;
    sh:path :knownAs .

