        sh:NodeShape ;
    esh:disjointWith :Female,
        :Male,
        :Marriage,
        :Sex,
        :Woman ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :Ancestor-hasChild,
