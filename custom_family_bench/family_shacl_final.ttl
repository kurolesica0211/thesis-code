@prefix : <http://example.com/family_TBOX.ttl#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix esh: <http://example.org/esh#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Ancestor a rdfs:Class,
        sh:NodeShape ;
    esh:disjointWith :Female,
        :Male,
        :Marriage,
        :Sex ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :Ancestor-hasChild,
        :Ancestor-hasDaughter,
        :Ancestor-hasSon,
        :Ancestor-isAncestorOf,
        :Ancestor-isFatherOf,
        :Ancestor-isMotherOf,
        :Ancestor-isParentOf,
        :AnnotationProperty_alsoKnownAs,
        :AnnotationProperty_formerlyKnownAs,
        :AnnotationProperty_hasBirthYear,
        :AnnotationProperty_hasDeathYear,
        :AnnotationProperty_hasMarriageYear,
        :AnnotationProperty_knownAs,
        :Man-hasSex,
        :Man-isBrotherOf,
        :Man-isFatherOf,
        :Man-isHusbandOf,
        :Man-isMalePartnerIn,
        :Man-isSonOf,
        :Man-isUncleOf,
        :Person-hasAncestor,
        :Person-hasBrother,
        :Person-hasFather,
        :Person-hasHusband,
        :Person-hasMother,
        :Person-hasParent,
        :Person-hasRelation,
        :Person-hasSex,
        :Person-hasSister,
        :Person-hasSpouse,
        :Person-hasWife,
        :Person-isBloodrelationOf,
        :Person-isChildOf,
        :Person-isPartnerIn,
        :Person-isSiblingOf,
        :Person-isSpouseOf,
        :Woman-hasSex,
        :Woman-isAuntOf,
        :Woman-isDaughterOf,
        :Woman-isFemalePartnerIn,
        :Woman-isMotherOf,
        :Woman-isSisterOf,
        :Woman-isWifeOf ;
    sh:rule esh:InferTypeRule_DomainEntity,
        esh:InferTypeRule_Person .

:DomainEntity a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :Ancestor-hasChild,
        :Ancestor-hasDaughter,
        :Ancestor-hasSon,
        :Ancestor-isAncestorOf,
        :Ancestor-isFatherOf,
        :Ancestor-isMotherOf,
        :Ancestor-isParentOf,
        :AnnotationProperty_alsoKnownAs,
        :AnnotationProperty_formerlyKnownAs,
        :AnnotationProperty_hasBirthYear,
        :AnnotationProperty_hasDeathYear,
        :AnnotationProperty_hasMarriageYear,
        :AnnotationProperty_knownAs,
        :Man-hasSex,
        :Man-isBrotherOf,
        :Man-isFatherOf,
        :Man-isHusbandOf,
        :Man-isMalePartnerIn,
        :Man-isSonOf,
        :Man-isUncleOf,
        :Marriage-hasFemalePartner,
        :Marriage-hasMalePartner,
        :Marriage-hasPartner,
        :Person-hasAncestor,
        :Person-hasBrother,
        :Person-hasFather,
        :Person-hasHusband,
        :Person-hasMother,
        :Person-hasParent,
        :Person-hasRelation,
        :Person-hasSex,
        :Person-hasSister,
        :Person-hasSpouse,
        :Person-hasWife,
        :Person-isBloodrelationOf,
        :Person-isChildOf,
        :Person-isPartnerIn,
        :Person-isSiblingOf,
        :Person-isSpouseOf,
        :Woman-hasSex,
        :Woman-isAuntOf,
        :Woman-isDaughterOf,
        :Woman-isFemalePartnerIn,
        :Woman-isMotherOf,
        :Woman-isSisterOf,
        :Woman-isWifeOf .

:Female a rdfs:Class,
        sh:NodeShape ;
    esh:disjointWith :Ancestor,
        :Male,
        :Man,
        :Marriage,
        :Person,
        :Woman ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :AnnotationProperty_alsoKnownAs,
        :AnnotationProperty_formerlyKnownAs,
        :AnnotationProperty_hasBirthYear,
        :AnnotationProperty_hasDeathYear,
        :AnnotationProperty_hasMarriageYear,
        :AnnotationProperty_knownAs ;
    sh:rule esh:InferTypeRule_DomainEntity,
        esh:InferTypeRule_Sex .

:Male a rdfs:Class,
        sh:NodeShape ;
    esh:disjointWith :Ancestor,
        :Female,
        :Man,
        :Marriage,
        :Person,
        :Woman ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property :AnnotationProperty_alsoKnownAs,
        :AnnotationProperty_formerlyKnownAs,
        :AnnotationProperty_hasBirthYear,
        :AnnotationProperty_hasDeathYear,
        :AnnotationProperty_hasMarriageYear,
        :AnnotationProperty_knownAs ;
    sh:rule esh:InferTypeRule_DomainEntity,
        esh:InferTypeRule_Sex .

