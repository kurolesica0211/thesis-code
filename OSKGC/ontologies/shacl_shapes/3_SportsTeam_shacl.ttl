@prefix cls:           <https://HeraclesWang.github.io/OSKGC/3_SportsTeam/class#> .
@prefix dash:          <http://datashapes.org/dash#> .
@prefix dc:            <http://purl.org/dc/elements/1.1/> .
@prefix dct:           <http://purl.org/dc/terms/> .
@prefix graphql:       <http://datashapes.org/graphql#> .
@prefix onto:          <https://HeraclesWang.github.io/OSKGC/3_SportsTeam#> .
@prefix owl:           <http://www.w3.org/2002/07/owl#> .
@prefix owl2sh-closed: <http://data.sparna.fr/ontologies/owl2sh-closed#> .
@prefix rdf:           <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rel:           <https://HeraclesWang.github.io/OSKGC/3_SportsTeam/relation#> .
@prefix sh:            <http://www.w3.org/ns/shacl#> .
@prefix swa:           <http://topbraid.org/swa#> .
@prefix tosh:          <http://topbraid.org/tosh#> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .

<http://dbpedia.org/ontology/Organisation-numberOfMembers>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:numberOfMembers .

<http://dbpedia.org/ontology/Organisation-champions>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:champions .

<http://dbpedia.org/ontology/Organisation-location>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:location .

<http://dbpedia.org/ontology/Place>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Place-isPartOf> , <http://dbpedia.org/ontology/Place-language> , <http://dbpedia.org/ontology/Place-country> , <http://dbpedia.org/ontology/Place-leader> , <http://dbpedia.org/ontology/Place-mayor> , <http://dbpedia.org/ontology/Place-demonym> , <http://dbpedia.org/ontology/Place-capital> .

<http://dbpedia.org/ontology/Person>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Person-club> , <http://dbpedia.org/ontology/Person-birthPlace> .

<http://dbpedia.org/ontology/Organisation-league>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:league .

<http://dbpedia.org/ontology/ArchitecturalStructure>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/ArchitecturalStructure-operator> , <http://dbpedia.org/ontology/ArchitecturalStructure-location> , <http://dbpedia.org/ontology/ArchitecturalStructure-tenant> , <http://dbpedia.org/ontology/ArchitecturalStructure-owner> .

<http://dbpedia.org/ontology/ArchitecturalStructure-owner>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:owner .

<http://dbpedia.org/ontology/ArchitecturalStructure-location>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:location .

<http://dbpedia.org/ontology/Place-mayor>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:mayor .

<http://dbpedia.org/ontology/Place-language>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Language> ;
        sh:path   rel:language .

<http://dbpedia.org/ontology/Place-country>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:country .

<http://dbpedia.org/ontology/Organisation-ground>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> , <http://dbpedia.org/ontology/ArchitecturalStructure> , <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:ground .

<http://dbpedia.org/ontology/Organisation-nickname>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:nickname .

<http://dbpedia.org/ontology/Organisation-season>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/FootballLeagueSeason> , xsd:gYear ;
        sh:path   rel:season .

<http://dbpedia.org/ontology/Organisation-manager>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:manager .

<http://dbpedia.org/ontology/ArchitecturalStructure-tenant>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:tenant .

<http://dbpedia.org/ontology/ArchitecturalStructure-operator>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:operator .

<http://dbpedia.org/ontology/Organisation-city>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:city .

<http://dbpedia.org/ontology/Place-isPartOf>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:isPartOf .

<http://dbpedia.org/ontology/Place-leader>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:leader .

<http://dbpedia.org/ontology/Person-club>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:club .

<http://dbpedia.org/ontology/Organisation-country>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:country .

<http://dbpedia.org/ontology/Organisation>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Organisation-country> , <http://dbpedia.org/ontology/Organisation-numberOfMembers> , <http://dbpedia.org/ontology/Organisation-ground> , <http://dbpedia.org/ontology/Organisation-city> , <http://dbpedia.org/ontology/Organisation-state> , <http://dbpedia.org/ontology/Organisation-champions> , <http://dbpedia.org/ontology/Organisation-fullName> , <http://dbpedia.org/ontology/Organisation-manager> , <http://dbpedia.org/ontology/Organisation-nickname> , <http://dbpedia.org/ontology/Organisation-league> , <http://dbpedia.org/ontology/Organisation-location> , <http://dbpedia.org/ontology/Organisation-season> .

<http://dbpedia.org/ontology/Place-capital>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:capital .

<http://dbpedia.org/ontology/Person-birthPlace>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:birthPlace .

<http://dbpedia.org/ontology/Place-demonym>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/EthnicGroup> ;
        sh:path   rel:demonym .

<http://dbpedia.org/ontology/Organisation-state>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:state .

<http://dbpedia.org/ontology/Organisation-fullName>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:fullName .
