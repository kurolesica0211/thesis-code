@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rel: <https://HeraclesWang.github.io/OSKGC/3_SportsTeam/relation#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://dbpedia.org/ontology/ArchitecturalStructure> a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property <http://dbpedia.org/ontology/ArchitecturalStructure-location>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-operator>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-owner>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-tenant> .

<http://dbpedia.org/ontology/Organisation> a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property <http://dbpedia.org/ontology/Organisation-champions>,
        <http://dbpedia.org/ontology/Organisation-city>,
        <http://dbpedia.org/ontology/Organisation-country>,
        <http://dbpedia.org/ontology/Organisation-fullName>,
        <http://dbpedia.org/ontology/Organisation-ground>,
        <http://dbpedia.org/ontology/Organisation-league>,
        <http://dbpedia.org/ontology/Organisation-location>,
        <http://dbpedia.org/ontology/Organisation-manager>,
        <http://dbpedia.org/ontology/Organisation-nickname>,
        <http://dbpedia.org/ontology/Organisation-numberOfMembers>,
        <http://dbpedia.org/ontology/Organisation-season>,
        <http://dbpedia.org/ontology/Organisation-state> .

<http://dbpedia.org/ontology/Person> a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property <http://dbpedia.org/ontology/Person-birthPlace>,
        <http://dbpedia.org/ontology/Person-club> .

<http://dbpedia.org/ontology/Place> a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property <http://dbpedia.org/ontology/Place-capital>,
        <http://dbpedia.org/ontology/Place-country>,
        <http://dbpedia.org/ontology/Place-demonym>,
        <http://dbpedia.org/ontology/Place-isPartOf>,
        <http://dbpedia.org/ontology/Place-language>,
        <http://dbpedia.org/ontology/Place-leader>,
        <http://dbpedia.org/ontology/Place-mayor> .

<http://dbpedia.org/ontology/ArchitecturalStructure-location> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:location .

<http://dbpedia.org/ontology/ArchitecturalStructure-operator> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:operator .

<http://dbpedia.org/ontology/ArchitecturalStructure-owner> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:owner .

<http://dbpedia.org/ontology/ArchitecturalStructure-tenant> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:tenant .

<http://dbpedia.org/ontology/Organisation-champions> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:champions .

<http://dbpedia.org/ontology/Organisation-city> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:city .

<http://dbpedia.org/ontology/Organisation-country> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:country .

<http://dbpedia.org/ontology/Organisation-fullName> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:fullName .

<http://dbpedia.org/ontology/Organisation-ground> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/ArchitecturalStructure>,
        <http://dbpedia.org/ontology/Organisation>,
        <http://dbpedia.org/ontology/Place> ;
    sh:path rel:ground .

<http://dbpedia.org/ontology/Organisation-league> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:league .

<http://dbpedia.org/ontology/Organisation-location> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:location .

<http://dbpedia.org/ontology/Organisation-manager> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Person> ;
    sh:path rel:manager .

<http://dbpedia.org/ontology/Organisation-nickname> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:nickname .

<http://dbpedia.org/ontology/Organisation-numberOfMembers> a sh:PropertyShape ;
    sh:datatype xsd:decimal ;
    sh:path rel:numberOfMembers .

<http://dbpedia.org/ontology/Organisation-season> a sh:PropertyShape ;
    sh:datatype xsd:gYear ;
    sh:path rel:season .

<http://dbpedia.org/ontology/Organisation-state> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:state .

<http://dbpedia.org/ontology/Person-birthPlace> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:birthPlace .

<http://dbpedia.org/ontology/Person-club> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:club .

<http://dbpedia.org/ontology/Place-capital> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:capital .

<http://dbpedia.org/ontology/Place-country> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:country .

<http://dbpedia.org/ontology/Place-demonym> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/EthnicGroup> ;
    sh:path rel:demonym .

<http://dbpedia.org/ontology/Place-isPartOf> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:isPartOf .

<http://dbpedia.org/ontology/Place-language> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Language> ;
    sh:path rel:language .

<http://dbpedia.org/ontology/Place-leader> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Person> ;
    sh:path rel:leader .

<http://dbpedia.org/ontology/Place-mayor> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Person> ;
    sh:path rel:mayor .

