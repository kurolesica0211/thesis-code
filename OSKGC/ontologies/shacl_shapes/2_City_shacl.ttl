@prefix cls:           <https://HeraclesWang.github.io/OSKGC/2_City/class#> .
@prefix dash:          <http://datashapes.org/dash#> .
@prefix dc:            <http://purl.org/dc/elements/1.1/> .
@prefix dct:           <http://purl.org/dc/terms/> .
@prefix graphql:       <http://datashapes.org/graphql#> .
@prefix onto:          <https://HeraclesWang.github.io/OSKGC/2_City#> .
@prefix owl:           <http://www.w3.org/2002/07/owl#> .
@prefix owl2sh-closed: <http://data.sparna.fr/ontologies/owl2sh-closed#> .
@prefix rdf:           <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rel:           <https://HeraclesWang.github.io/OSKGC/2_City/relation#> .
@prefix sh:            <http://www.w3.org/ns/shacl#> .
@prefix swa:           <http://topbraid.org/swa#> .
@prefix tosh:          <http://topbraid.org/tosh#> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .

<http://dbpedia.org/ontology/Place-leaderTitle>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> , <http://dbpedia.org/ontology/PersonFunction> ;
        sh:path   rel:leaderTitle .

<http://dbpedia.org/ontology/Place-areaCode>
        rdf:type  sh:PropertyShape ;
        sh:class  cls:Code ;
        sh:path   rel:areaCode .

<http://dbpedia.org/ontology/Place-postalCode>
        rdf:type  sh:PropertyShape ;
        sh:class  cls:Code ;
        sh:path   rel:postalCode .

<http://dbpedia.org/ontology/Place>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Place-areaCode> , <http://dbpedia.org/ontology/Place-ethnicGroup> , <http://dbpedia.org/ontology/Place-isPartOf> , <http://dbpedia.org/ontology/Place-largestCity> , <http://dbpedia.org/ontology/Place-populationMetro> , <http://dbpedia.org/ontology/Place-areaOfLand> , <http://dbpedia.org/ontology/Place-timeZone> , <http://dbpedia.org/ontology/Place-language> , <http://dbpedia.org/ontology/Place-country> , <http://dbpedia.org/ontology/Place-leader> , <http://dbpedia.org/ontology/Place-demonym> , <http://dbpedia.org/ontology/Place-governmentType> , <http://dbpedia.org/ontology/Place-countySeat> , <http://dbpedia.org/ontology/Place-postalCode> , <http://dbpedia.org/ontology/Place-areaOfWater> , <http://dbpedia.org/ontology/Place-capital> , <http://dbpedia.org/ontology/Place-leaderTitle> , <http://dbpedia.org/ontology/Place-utcOffset> , <http://dbpedia.org/ontology/Place-elevationAboveTheSeaLevel> , <http://dbpedia.org/ontology/Place-areaTotal> , <http://dbpedia.org/ontology/Place-populationDensity> .

<http://dbpedia.org/ontology/Place-utcOffset>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:utcOffset .

<http://dbpedia.org/ontology/Place-populationDensity>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:populationDensity .

<http://dbpedia.org/ontology/Place-language>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Language> ;
        sh:path   rel:language .

<http://dbpedia.org/ontology/Place-country>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:country .

<http://dbpedia.org/ontology/Place-governmentType>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/TopicalConcept> ;
        sh:path   rel:governmentType .

<http://dbpedia.org/ontology/Organisation-isPartOf>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> , <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:isPartOf .

<http://dbpedia.org/ontology/Place-areaOfWater>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:areaOfWater .

<http://dbpedia.org/ontology/Place-populationMetro>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:populationMetro .

<http://dbpedia.org/ontology/Place-areaTotal>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:areaTotal .

<http://dbpedia.org/ontology/Place-largestCity>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:largestCity .

<http://dbpedia.org/ontology/Place-countySeat>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:countySeat .

<http://dbpedia.org/ontology/Place-elevationAboveTheSeaLevel>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:elevationAboveTheSeaLevel .

<http://dbpedia.org/ontology/Place-isPartOf>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> , <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:isPartOf .

<http://dbpedia.org/ontology/Place-leader>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:leader .

<http://dbpedia.org/ontology/Organisation>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Organisation-isPartOf> .

<http://dbpedia.org/ontology/Place-areaOfLand>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:areaOfLand .

<http://dbpedia.org/ontology/Place-capital>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:capital .

<http://dbpedia.org/ontology/Place-timeZone>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/TopicalConcept> ;
        sh:path   rel:timeZone .

<http://dbpedia.org/ontology/Place-demonym>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/EthnicGroup> ;
        sh:path   rel:demonym .

<http://dbpedia.org/ontology/Place-ethnicGroup>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/EthnicGroup> ;
        sh:path   rel:ethnicGroup .
