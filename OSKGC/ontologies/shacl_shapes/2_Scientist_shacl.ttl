@prefix cls:           <https://HeraclesWang.github.io/OSKGC/2_Scientist/class#> .
@prefix dash:          <http://datashapes.org/dash#> .
@prefix dc:            <http://purl.org/dc/elements/1.1/> .
@prefix dct:           <http://purl.org/dc/terms/> .
@prefix graphql:       <http://datashapes.org/graphql#> .
@prefix onto:          <https://HeraclesWang.github.io/OSKGC/2_Scientist#> .
@prefix owl:           <http://www.w3.org/2002/07/owl#> .
@prefix owl2sh-closed: <http://data.sparna.fr/ontologies/owl2sh-closed#> .
@prefix rdf:           <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rel:           <https://HeraclesWang.github.io/OSKGC/2_Scientist/relation#> .
@prefix sh:            <http://www.w3.org/ns/shacl#> .
@prefix swa:           <http://topbraid.org/swa#> .
@prefix tosh:          <http://topbraid.org/tosh#> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .

<http://dbpedia.org/ontology/Place-leaderTitle>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/PersonFunction> ;
        sh:path   rel:leaderTitle .

<http://dbpedia.org/ontology/Place-foundingDate>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:foundingDate .

<http://dbpedia.org/ontology/Person-knownFor>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/TopicalConcept> ;
        sh:path   rel:knownFor .

<http://dbpedia.org/ontology/Organisation-affiliation>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:affiliation .

<http://dbpedia.org/ontology/Place>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Place-foundingDate> , <http://dbpedia.org/ontology/Place-leader> , <http://dbpedia.org/ontology/Place-governmentType> , <http://dbpedia.org/ontology/Place-capital> , <http://dbpedia.org/ontology/Place-leaderTitle> , <http://dbpedia.org/ontology/Place-areaTotal> , <http://dbpedia.org/ontology/Place-populationTotal> .

<http://dbpedia.org/ontology/Person>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Person-knownFor> , <http://dbpedia.org/ontology/Person-almaMater> , <http://dbpedia.org/ontology/Person-citizenship> , <http://dbpedia.org/ontology/Person-birthDate> , <http://dbpedia.org/ontology/Person-doctoralAdvisor> , <http://dbpedia.org/ontology/Person-birthName> , <http://dbpedia.org/ontology/Person-birthPlace> , <http://dbpedia.org/ontology/Person-deathPlace> , <http://dbpedia.org/ontology/Person-nationality> , <http://dbpedia.org/ontology/Person-residence> , <http://dbpedia.org/ontology/Person-award> , <http://dbpedia.org/ontology/Person-deathDate> , <http://dbpedia.org/ontology/Person-influencedBy> , <http://dbpedia.org/ontology/Person-professionalField> .

<http://dbpedia.org/ontology/Person-residence>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:residence .

<http://dbpedia.org/ontology/Person-birthName>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:birthName .

<http://dbpedia.org/ontology/Person-almaMater>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:almaMater .

<http://dbpedia.org/ontology/EthnicGroup>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/EthnicGroup-language> .

<http://dbpedia.org/ontology/Person-deathPlace>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:deathPlace .

<http://dbpedia.org/ontology/Place-governmentType>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/TopicalConcept> ;
        sh:path   rel:governmentType .

<http://dbpedia.org/ontology/Person-professionalField>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/TopicalConcept> ;
        sh:path   rel:professionalField .

<http://dbpedia.org/ontology/Person-doctoralAdvisor>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:doctoralAdvisor .

<http://dbpedia.org/ontology/Person-influencedBy>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:influencedBy .

<http://dbpedia.org/ontology/Person-nationality>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:nationality .

<http://dbpedia.org/ontology/Person-birthDate>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:birthDate .

<http://dbpedia.org/ontology/Place-areaTotal>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:areaTotal .

<http://dbpedia.org/ontology/Place-leader>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:leader .

<http://dbpedia.org/ontology/Person-award>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Award> ;
        sh:path   rel:award .

<http://dbpedia.org/ontology/Person-citizenship>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:citizenship .

<http://dbpedia.org/ontology/Organisation>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Organisation-affiliation> .

<http://dbpedia.org/ontology/Place-capital>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:capital .

<http://dbpedia.org/ontology/Place-populationTotal>
        rdf:type  sh:PropertyShape ;
        sh:class  xsd:decimal ;
        sh:path   rel:populationTotal .

<http://dbpedia.org/ontology/Person-birthPlace>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:birthPlace .

<http://dbpedia.org/ontology/Person-deathDate>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:deathDate .

<http://dbpedia.org/ontology/EthnicGroup-language>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:language .
