@prefix cls:           <https://HeraclesWang.github.io/OSKGC/2_ComicsCharacter/class#> .
@prefix dash:          <http://datashapes.org/dash#> .
@prefix dc:            <http://purl.org/dc/elements/1.1/> .
@prefix dct:           <http://purl.org/dc/terms/> .
@prefix graphql:       <http://datashapes.org/graphql#> .
@prefix onto:          <https://HeraclesWang.github.io/OSKGC/2_ComicsCharacter#> .
@prefix owl:           <http://www.w3.org/2002/07/owl#> .
@prefix owl2sh-closed: <http://data.sparna.fr/ontologies/owl2sh-closed#> .
@prefix rdf:           <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rel:           <https://HeraclesWang.github.io/OSKGC/2_ComicsCharacter/relation#> .
@prefix sh:            <http://www.w3.org/ns/shacl#> .
@prefix swa:           <http://topbraid.org/swa#> .
@prefix tosh:          <http://topbraid.org/tosh#> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .

<http://dbpedia.org/ontology/FictionalCharacter-broadcastedBy>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:broadcastedBy .

<http://dbpedia.org/ontology/Work>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Work-starring> , <http://dbpedia.org/ontology/Work-distributor> .

<http://dbpedia.org/ontology/FictionalCharacter-firstAppearanceInFilm>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Work> ;
        sh:path   rel:firstAppearanceInFilm .

<http://dbpedia.org/ontology/Organisation-location>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/ArchitecturalStructure> , <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:location .

<http://dbpedia.org/ontology/Person>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Person-award> , <http://dbpedia.org/ontology/Person-birthPlace> , <http://dbpedia.org/ontology/Person-nationality> .

<http://dbpedia.org/ontology/FictionalCharacter-series>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Work> ;
        sh:path   rel:series .

<http://dbpedia.org/ontology/FictionalCharacter-alternativeName>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/FictionalCharacter> ;
        sh:path   rel:alternativeName .

<http://dbpedia.org/ontology/FictionalCharacter-firstAired>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:firstAired .

<http://dbpedia.org/ontology/FictionalCharacter-lastAired>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:lastAired .

<http://dbpedia.org/ontology/FictionalCharacter-voice>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:voice .

<http://dbpedia.org/ontology/Work-distributor>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:distributor .

<http://dbpedia.org/ontology/Person-nationality>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:nationality .

<http://dbpedia.org/ontology/FictionalCharacter-starring>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:starring .

<http://dbpedia.org/ontology/FictionalCharacter-fullName>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/FictionalCharacter> ;
        sh:path   rel:fullName .

<http://dbpedia.org/ontology/Person-award>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Award> ;
        sh:path   rel:award .

<http://dbpedia.org/ontology/Organisation>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Organisation-location> , <http://dbpedia.org/ontology/Organisation-foundedBy> .

<http://dbpedia.org/ontology/FictionalCharacter-creator>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:creator .

<http://dbpedia.org/ontology/Organisation-foundedBy>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:foundedBy .

<http://dbpedia.org/ontology/Work-starring>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:starring .

<http://dbpedia.org/ontology/Person-birthPlace>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:birthPlace .

<http://dbpedia.org/ontology/FictionalCharacter>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/FictionalCharacter-fullName> , <http://dbpedia.org/ontology/FictionalCharacter-series> , <http://dbpedia.org/ontology/FictionalCharacter-starring> , <http://dbpedia.org/ontology/FictionalCharacter-firstAired> , <http://dbpedia.org/ontology/FictionalCharacter-voice> , <http://dbpedia.org/ontology/FictionalCharacter-lastAired> , <http://dbpedia.org/ontology/FictionalCharacter-alternativeName> , <http://dbpedia.org/ontology/FictionalCharacter-creator> , <http://dbpedia.org/ontology/FictionalCharacter-firstAppearanceInFilm> , <http://dbpedia.org/ontology/FictionalCharacter-broadcastedBy> .
