@prefix cls:           <https://HeraclesWang.github.io/OSKGC/3_Film/class#> .
@prefix dash:          <http://datashapes.org/dash#> .
@prefix dc:            <http://purl.org/dc/elements/1.1/> .
@prefix dct:           <http://purl.org/dc/terms/> .
@prefix graphql:       <http://datashapes.org/graphql#> .
@prefix onto:          <https://HeraclesWang.github.io/OSKGC/3_Film#> .
@prefix owl:           <http://www.w3.org/2002/07/owl#> .
@prefix owl2sh-closed: <http://data.sparna.fr/ontologies/owl2sh-closed#> .
@prefix rdf:           <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rel:           <https://HeraclesWang.github.io/OSKGC/3_Film/relation#> .
@prefix sh:            <http://www.w3.org/ns/shacl#> .
@prefix swa:           <http://topbraid.org/swa#> .
@prefix tosh:          <http://topbraid.org/tosh#> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .

<http://dbpedia.org/ontology/Work-producer>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> , <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:producer .

<http://dbpedia.org/ontology/Work>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Work-releaseDate> , <http://dbpedia.org/ontology/Work-director> , <http://dbpedia.org/ontology/Work-imdbId> , <http://dbpedia.org/ontology/Work-musicComposer> , <http://dbpedia.org/ontology/Work-writer> , <http://dbpedia.org/ontology/Work-runtime> , <http://dbpedia.org/ontology/Work-starring> , <http://dbpedia.org/ontology/Work-producer> , <http://dbpedia.org/ontology/Work-distributor> , <http://dbpedia.org/ontology/Work-gross> , <http://dbpedia.org/ontology/Work-language> , <http://dbpedia.org/ontology/Work-editor> , <http://dbpedia.org/ontology/Work-budget> , <http://dbpedia.org/ontology/Work-cinematography> , <http://dbpedia.org/ontology/Work-broadcastedBy> .

<http://dbpedia.org/ontology/Work-language>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Language> ;
        sh:path   rel:language .

<http://dbpedia.org/ontology/Person>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Person-deathPlace> , <http://dbpedia.org/ontology/Person-activeYearsStartYear> , <http://dbpedia.org/ontology/Person-birthDate> , <http://dbpedia.org/ontology/Person-birthPlace> , <http://dbpedia.org/ontology/Person-birthYear> .

<http://dbpedia.org/ontology/Work-cinematography>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:cinematography .

<http://dbpedia.org/ontology/Work-editor>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:editor .

<http://dbpedia.org/ontology/Person-deathPlace>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:deathPlace .

<http://dbpedia.org/ontology/Work-releaseDate>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:releaseDate .

<http://dbpedia.org/ontology/Work-distributor>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:distributor .

<http://dbpedia.org/ontology/Work-gross>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:gross .

<http://dbpedia.org/ontology/Work-broadcastedBy>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:broadcastedBy .

<http://dbpedia.org/ontology/Organisation-type>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/TopicalConcept> ;
        sh:path   rel:type .

<http://dbpedia.org/ontology/Work-musicComposer>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:musicComposer .

<http://dbpedia.org/ontology/Work-imdbId>
        rdf:type  sh:PropertyShape ;
        sh:class  cls:Code ;
        sh:path   rel:imdbId .

<http://dbpedia.org/ontology/Work-writer>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:writer .

<http://dbpedia.org/ontology/Person-activeYearsStartYear>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:gYear ;
        sh:path   rel:activeYearsStartYear .

<http://dbpedia.org/ontology/Person-birthDate>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:birthDate .

<http://dbpedia.org/ontology/Work-director>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:director .

<http://dbpedia.org/ontology/Work-budget>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:budget .

<http://dbpedia.org/ontology/Organisation>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Organisation-type> , <http://dbpedia.org/ontology/Organisation-foundedBy> .

<http://dbpedia.org/ontology/Organisation-foundedBy>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:foundedBy .

<http://dbpedia.org/ontology/Work-starring>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:starring .

<http://dbpedia.org/ontology/Person-birthYear>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:gYear ;
        sh:path   rel:birthYear .

<http://dbpedia.org/ontology/Person-birthPlace>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:birthPlace .

<http://dbpedia.org/ontology/Work-runtime>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:runtime .
