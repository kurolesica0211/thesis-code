<http://dbpedia.org/ontology/Place-language>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Language> ;
        sh:path   rel:language .

<http://dbpedia.org/ontology/Place-country>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:country .

<http://dbpedia.org/ontology/Organisation>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Organisation-foundationPlace> , <http://dbpedia.org/ontology/Organisation-keyPerson> , <http://dbpedia.org/ontology/Organisation-bedCount> , <http://dbpedia.org/ontology/Organisation-chancellor> , <http://dbpedia.org/ontology/Organisation-location> , <http://dbpedia.org/ontology/Organisation-country> .

<http://dbpedia.org/ontology/Organisation-country>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
