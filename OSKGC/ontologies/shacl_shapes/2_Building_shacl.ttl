@prefix tosh:          <http://topbraid.org/tosh#> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .

<http://dbpedia.org/ontology/ArchitecturalStructure-height>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:height .

<http://dbpedia.org/ontology/Place-governingBody>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:governingBody .

<http://dbpedia.org/ontology/Organisation-foundationPlace>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:foundationPlace .

<http://dbpedia.org/ontology/ArchitecturalStructure-completionDate>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:completionDate .

<http://dbpedia.org/ontology/ArchitecturalStructure-buildingStartDate>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:buildingStartDate .

<http://dbpedia.org/ontology/ArchitecturalStructure-inaugurationDate>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:inaugurationDate .

<http://dbpedia.org/ontology/Person-deathPlace>
