<http://dbpedia.org/ontology/Person-birthPlace>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:birthPlace .

<http://dbpedia.org/ontology/Person-significantBuilding>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/ArchitecturalStructure> , <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:significantBuilding .

<http://dbpedia.org/ontology/Place-ethnicGroup>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/EthnicGroup> ;
        sh:path   rel:ethnicGroup .

<http://dbpedia.org/ontology/Person>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Person-origin> , <http://dbpedia.org/ontology/Person-deathPlace> , <http://dbpedia.org/ontology/Person-birthPlace> , <http://dbpedia.org/ontology/Person-significantBuilding> .

<http://dbpedia.org/ontology/ArchitecturalStructure-addedToTheNationalRegisterOfHistoricPlaces>
        rdf:type     sh:PropertyShape ;
        sh:datatype  xsd:date ;
        sh:path      rel:addedToTheNationalRegisterOfHistoricPlaces .

<http://dbpedia.org/ontology/ArchitecturalStructure-location>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/ArchitecturalStructure> , <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:location .

<http://dbpedia.org/ontology/ArchitecturalStructure-yearOfConstruction>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:gYear ;
        sh:path   rel:yearOfConstruction .

<http://dbpedia.org/ontology/ArchitecturalStructure-architecturalStyle>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/TopicalConcept> ;
        sh:path   rel:architecturalStyle .

<http://dbpedia.org/ontology/ArchitecturalStructure-floorCount>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:floorCount .

<http://dbpedia.org/ontology/Place-currency>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Currency> ;
        sh:path   rel:currency .

<http://dbpedia.org/ontology/ArchitecturalStructure-architect>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> , <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:architect .

<http://dbpedia.org/ontology/Organisation-keyPerson>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:keyPerson .

<http://dbpedia.org/ontology/Place-isPartOf>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:isPartOf .

<http://dbpedia.org/ontology/Place>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Place-ethnicGroup> , <http://dbpedia.org/ontology/Place-isPartOf> , <http://dbpedia.org/ontology/Place-language> , <http://dbpedia.org/ontology/Place-country> , <http://dbpedia.org/ontology/Place-leader> , <http://dbpedia.org/ontology/Place-demonym> , <http://dbpedia.org/ontology/Place-governingBody> , <http://dbpedia.org/ontology/Place-capital> , <http://dbpedia.org/ontology/Place-leaderTitle> , <http://dbpedia.org/ontology/Place-currency> .

<http://dbpedia.org/ontology/Organisation-location>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/ArchitecturalStructure> , <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:location .

<http://dbpedia.org/ontology/ArchitecturalStructure>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/ArchitecturalStructure-addedToTheNationalRegisterOfHistoricPlaces> , <http://dbpedia.org/ontology/ArchitecturalStructure-NationalRegisterOfHistoricPlacesReferenceNumber> , <http://dbpedia.org/ontology/ArchitecturalStructure-country> , <http://dbpedia.org/ontology/ArchitecturalStructure-currentTenants> , <http://dbpedia.org/ontology/ArchitecturalStructure-buildingStartYear> , <http://dbpedia.org/ontology/ArchitecturalStructure-cost> , <http://dbpedia.org/ontology/ArchitecturalStructure-address> , <http://dbpedia.org/ontology/ArchitecturalStructure-floorArea> , <http://dbpedia.org/ontology/ArchitecturalStructure-numberOfRooms> , <http://dbpedia.org/ontology/ArchitecturalStructure-tenant> , <http://dbpedia.org/ontology/ArchitecturalStructure-floorCount> , <http://dbpedia.org/ontology/ArchitecturalStructure-owner> , <http://dbpedia.org/ontology/ArchitecturalStructure-completionDate> , <http://dbpedia.org/ontology/ArchitecturalStructure-developer> , <http://dbpedia.org/ontology/ArchitecturalStructure-height> , <http://dbpedia.org/ontology/ArchitecturalStructure-location> , <http://dbpedia.org/ontology/ArchitecturalStructure-buildingStartDate> , <http://dbpedia.org/ontology/ArchitecturalStructure-completionYear> , <http://dbpedia.org/ontology/ArchitecturalStructure-yearOfConstruction> , <http://dbpedia.org/ontology/ArchitecturalStructure-architecturalStyle> , <http://dbpedia.org/ontology/ArchitecturalStructure-architect> , <http://dbpedia.org/ontology/ArchitecturalStructure-inaugurationDate> .

<http://dbpedia.org/ontology/ArchitecturalStructure-currentTenants>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:currentTenants .

<http://dbpedia.org/ontology/ArchitecturalStructure-cost>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:cost .

<http://dbpedia.org/ontology/ArchitecturalStructure-owner>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:owner .

<http://dbpedia.org/ontology/Organisation-chancellor>
        rdf:type  sh:PropertyShape ;
