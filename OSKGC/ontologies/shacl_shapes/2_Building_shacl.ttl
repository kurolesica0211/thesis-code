        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:deathPlace .

<http://dbpedia.org/ontology/ArchitecturalStructure-completionYear>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:gYear ;
        sh:path   rel:completionYear .

<http://dbpedia.org/ontology/ArchitecturalStructure-country>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:country .

<http://dbpedia.org/ontology/ArchitecturalStructure-floorArea>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:floorArea .

<http://dbpedia.org/ontology/ArchitecturalStructure-buildingStartYear>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:gYear ;
        sh:path   rel:buildingStartYear .

<http://dbpedia.org/ontology/Organisation-bedCount>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:bedCount .

<http://dbpedia.org/ontology/Place-capital>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:capital .

<http://dbpedia.org/ontology/Place-leaderTitle>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/PersonFunction> , <http://dbpedia.org/ontology/Organisation> ;
        sh:path   rel:leaderTitle .

<http://dbpedia.org/ontology/ArchitecturalStructure-address>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:address .

<http://dbpedia.org/ontology/Place-demonym>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/EthnicGroup> ;
        sh:path   rel:demonym .

<http://dbpedia.org/ontology/Place-leader>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Person> ;
        sh:path   rel:leader .

<http://dbpedia.org/ontology/ArchitecturalStructure-numberOfRooms>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:numberOfRooms .

<http://dbpedia.org/ontology/ArchitecturalStructure-NationalRegisterOfHistoricPlacesReferenceNumber>
        rdf:type  sh:PropertyShape ;
        sh:datatype  xsd:decimal ;
        sh:path   rel:NationalRegisterOfHistoricPlacesReferenceNumber .

<http://dbpedia.org/ontology/ArchitecturalStructure-developer>
        rdf:type  sh:PropertyShape ;
