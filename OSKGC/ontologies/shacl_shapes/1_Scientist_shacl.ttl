<http://dbpedia.org/ontology/Place-isPartOf>
        rdf:type  sh:PropertyShape ;
        sh:class  <http://dbpedia.org/ontology/Place> ;
        sh:path   rel:isPartOf .

<http://dbpedia.org/ontology/Place>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Place-areaCode> , <http://dbpedia.org/ontology/Place-gridReference> , <http://dbpedia.org/ontology/Place-isPartOf> , <http://dbpedia.org/ontology/Place-foundingYear> , <http://dbpedia.org/ontology/Place-foundingDate> , <http://dbpedia.org/ontology/Place-timeZone> , <http://dbpedia.org/ontology/Place-language> , <http://dbpedia.org/ontology/Place-country> , <http://dbpedia.org/ontology/Place-leader> , <http://dbpedia.org/ontology/Place-region> , <http://dbpedia.org/ontology/Place-demonym> , <http://dbpedia.org/ontology/Place-governmentType> , <http://dbpedia.org/ontology/Place-populationMetroDensity> , <http://dbpedia.org/ontology/Place-areaOfWater> , <http://dbpedia.org/ontology/Place-longName> , <http://dbpedia.org/ontology/Place-leaderTitle> , <http://dbpedia.org/ontology/Place-utcOffset> , <http://dbpedia.org/ontology/Place-areaTotal> , <http://dbpedia.org/ontology/Place-populationTotal> , <http://dbpedia.org/ontology/Place-percentageOfAreaWater> , <http://dbpedia.org/ontology/Place-officialLanguage> .

