<http://dbpedia.org/ontology/Person>
        rdf:type              sh:NodeShape , rdfs:Class ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Person-knownFor> , <http://dbpedia.org/ontology/Person-almaMater> , <http://dbpedia.org/ontology/Person-citizenship> , <http://dbpedia.org/ontology/Person-birthDate> , <http://dbpedia.org/ontology/Person-birthName> , <http://dbpedia.org/ontology/Person-birthPlace> , <http://dbpedia.org/ontology/Person-deathPlace> , <http://dbpedia.org/ontology/Person-nationality> , <http://dbpedia.org/ontology/Person-residence> , <http://dbpedia.org/ontology/Person-award> , <http://dbpedia.org/ontology/Person-deathDate> , <http://dbpedia.org/ontology/Person-influencedBy> , <http://dbpedia.org/ontology/Person-spouse> , <http://dbpedia.org/ontology/Person-professionalField> .

<http://dbpedia.org/ontology/Person-citizenship>
        rdf:type  sh:PropertyShape ;
