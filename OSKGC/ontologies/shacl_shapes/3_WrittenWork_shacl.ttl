<http://dbpedia.org/ontology/Work>
        rdf:type              rdfs:Class , sh:NodeShape ;
        sh:closed             true ;
        sh:ignoredProperties  ( rdf:type ) ;
        sh:property           <http://dbpedia.org/ontology/Work-releaseDate> , <http://dbpedia.org/ontology/Work-numberOfPages> , <http://dbpedia.org/ontology/Work-issnNumber> , <http://dbpedia.org/ontology/Work-LCCN_number> , <http://dbpedia.org/ontology/Work-genre> , <http://dbpedia.org/ontology/Work-mediaType> , <http://dbpedia.org/ontology/Work-academicDiscipline> , <http://dbpedia.org/ontology/Work-abbreviation> , <http://dbpedia.org/ontology/Work-isbnNumber> , <http://dbpedia.org/ontology/Work-impactFactor> , <http://dbpedia.org/ontology/Work-codenCode> , <http://dbpedia.org/ontology/Work-oclcNumber> , <http://dbpedia.org/ontology/Work-language> , <http://dbpedia.org/ontology/Work-precededBy> , <http://dbpedia.org/ontology/Work-editor> , <http://dbpedia.org/ontology/Work-literaryGenre> , <http://dbpedia.org/ontology/Work-author> , <http://dbpedia.org/ontology/Work-firstPublicationYear> , <http://dbpedia.org/ontology/Work-country> , <http://dbpedia.org/ontology/Work-followedBy> , <http://dbpedia.org/ontology/Work-publisher> .

