@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rel: <https://HeraclesWang.github.io/OSKGC/2_Monument/relation#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://dbpedia.org/ontology/ArchitecturalStructure> a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property <http://dbpedia.org/ontology/ArchitecturalStructure-category>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-dedicatedTo>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-designer>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-district>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-established>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-inaugurationDate>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-location>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-material>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-nativeName>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-owner>,
        <http://dbpedia.org/ontology/ArchitecturalStructure-state> .

<http://dbpedia.org/ontology/Place> a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property <http://dbpedia.org/ontology/Place-capital>,
        <http://dbpedia.org/ontology/Place-currency>,
        <http://dbpedia.org/ontology/Place-ethnicGroup>,
        <http://dbpedia.org/ontology/Place-hasToItsSoutheast>,
        <http://dbpedia.org/ontology/Place-hasToItsSouthwest>,
        <http://dbpedia.org/ontology/Place-hasToItsWest>,
        <http://dbpedia.org/ontology/Place-largestCity>,
        <http://dbpedia.org/ontology/Place-leaderTitle>,
        <http://dbpedia.org/ontology/Place-legislature>,
        <http://dbpedia.org/ontology/Place-location> .

<http://dbpedia.org/ontology/ArchitecturalStructure-category> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/TopicalConcept> ;
    sh:path rel:category .

<http://dbpedia.org/ontology/ArchitecturalStructure-dedicatedTo> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Person> ;
    sh:path rel:dedicatedTo .

<http://dbpedia.org/ontology/ArchitecturalStructure-designer> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Person> ;
    sh:path rel:designer .

<http://dbpedia.org/ontology/ArchitecturalStructure-district> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:district .

<http://dbpedia.org/ontology/ArchitecturalStructure-established> a sh:PropertyShape ;
    sh:datatype xsd:gYear ;
    sh:path rel:established .

<http://dbpedia.org/ontology/ArchitecturalStructure-inaugurationDate> a sh:PropertyShape ;
    sh:datatype xsd:date ;
    sh:path rel:inaugurationDate .

<http://dbpedia.org/ontology/ArchitecturalStructure-location> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:location .

<http://dbpedia.org/ontology/ArchitecturalStructure-material> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/ChemicalSubstance> ;
    sh:path rel:material .

<http://dbpedia.org/ontology/ArchitecturalStructure-nativeName> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/ArchitecturalStructure> ;
    sh:path rel:nativeName .

<http://dbpedia.org/ontology/ArchitecturalStructure-owner> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:owner .

<http://dbpedia.org/ontology/ArchitecturalStructure-state> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:state .

<http://dbpedia.org/ontology/Place-capital> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:capital .

<http://dbpedia.org/ontology/Place-currency> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Currency> ;
    sh:path rel:currency .

<http://dbpedia.org/ontology/Place-ethnicGroup> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/EthnicGroup> ;
    sh:path rel:ethnicGroup .

<http://dbpedia.org/ontology/Place-hasToItsSoutheast> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:hasToItsSoutheast .

<http://dbpedia.org/ontology/Place-hasToItsSouthwest> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:hasToItsSouthwest .

<http://dbpedia.org/ontology/Place-hasToItsWest> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:hasToItsWest .

<http://dbpedia.org/ontology/Place-largestCity> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:largestCity .

<http://dbpedia.org/ontology/Place-leaderTitle> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/PersonFunction> ;
    sh:path rel:leaderTitle .

<http://dbpedia.org/ontology/Place-legislature> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Organisation> ;
    sh:path rel:legislature .

<http://dbpedia.org/ontology/Place-location> a sh:PropertyShape ;
    sh:class <http://dbpedia.org/ontology/Place> ;
    sh:path rel:location .

