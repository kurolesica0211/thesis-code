@prefix : <http://example.com/family_TBOX.ttl#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix esh: <http://example.org/esh#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:DomainEntity a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) .

:Man a rdfs:Class,
        sh:NodeShape ;
    esh:disjointWith :Woman, :DomainEntity, :Person, :Male, :Female ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) .

:Person a rdfs:Class,
        sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) .

:Woman a rdfs:Class,
        sh:NodeShape ;
    esh:disjointWith :Man, :DomainEntity, :Person, :Male, :Female ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) .

:Sex a rdfs:Class,
        sh:NodeShape ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) .

:Male a rdfs:Class,
        sh:NodeShape ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) .

:Female a rdfs:Class,
        sh:NodeShape ;
    rdfs:subClassOf [ ] ;
    owl:intersectionOf [ ] ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) .

esh:DisjointWithConstraintComponent a sh:ConstraintComponent ;
    sh:nodeValidator esh:DisjointWithNodeValidator ;
    sh:parameter esh:DisjointWithParameter .

esh:DisjointWithNodeValidator a sh:SPARQLSelectValidator ;
    sh:message "Class disjointness violation: {$this} cannot be an instance of {$disjointWith}." ;
    sh:select"""
SELECT $this
WHERE {
    $this a $disjointWith .
}
""".

esh:DisjointWithParameter a sh:Parameter ;
    sh:description "Ensures the focus node is not an instance of the specified class." ;
    sh:name "disjoint with class" ;
    sh:nodeKind sh:IRI ;
    sh:path esh:disjointWith .